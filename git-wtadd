#!/bin/bash
# Creates a git worktree with relative paths so it works both inside the
# Docker container (/workspace/…) and on the Windows host (D:\…).
#
# Usage (run from inside the main repo):
#   git-wtadd <worktree-path> [<branch>] [extra git-worktree-add flags]
#
# Example:
#   cd /workspace/NServiceBus
#   git-wtadd /workspace/NServiceBus@feature-x feature-x

set -e

if [ -z "$1" ]; then
    echo "Usage: git-wtadd <worktree-path> [<branch>] [extra flags]"
    exit 1
fi

WORKTREE_PATH="$1"
shift

# If a branch name is given (first non-flag arg) and it doesn't exist locally
# or as a remote-tracking branch, automatically add -b to create it.
BRANCH=""
REMAINING=()
for arg in "$@"; do
    if [ -z "$BRANCH" ] && [[ "$arg" != -* ]]; then
        BRANCH="$arg"
    else
        REMAINING+=("$arg")
    fi
done

if [ -n "$BRANCH" ] && ! git show-ref --verify --quiet "refs/heads/$BRANCH" \
                     && ! git show-ref --verify --quiet "refs/remotes/origin/$BRANCH"; then
    git worktree add -b "$BRANCH" "$WORKTREE_PATH" "${REMAINING[@]}"
else
    git worktree add "$WORKTREE_PATH" "$@"
fi

# Resolve absolute paths
WORKTREE_ABS=$(realpath "$WORKTREE_PATH")
WORKTREE_NAME=$(basename "$WORKTREE_ABS")
MAIN_GIT_DIR=$(git rev-parse --git-dir)
MAIN_GIT_ABS=$(realpath "$MAIN_GIT_DIR")
WORKTREE_GITDIR="$MAIN_GIT_ABS/worktrees/$WORKTREE_NAME"

# Rewrite the .git file in the worktree (points back to main repo) —
# this is the file the Windows host Git client reads, so it must be relative.
REL_TO_MAIN=$(realpath --relative-to="$WORKTREE_ABS" "$WORKTREE_GITDIR")
echo "gitdir: $REL_TO_MAIN" > "$WORKTREE_ABS/.git"

# Rewrite the gitdir file in the main repo to use the Windows host path.
# Regular git operations in the worktree don't use this file — they follow
# the relative .git file above. The gitdir file is only read by worktree
# management commands (git worktree list/prune) and tools like GitKraken.
# Writing the Windows path makes the host the source of truth.
if [ -n "$HOST_WORKSPACE" ] && [ -n "$CONTAINER_WORKDIR" ]; then
    HOST_WS=$(echo "$HOST_WORKSPACE" | tr '\\' '/')
    HOST_PARENT=$(dirname "$HOST_WS")
    CONTAINER_PARENT=$(dirname "$CONTAINER_WORKDIR")

    LINUX_GITDIR=$(cat "$WORKTREE_GITDIR/gitdir")
    WIN_GITDIR="${LINUX_GITDIR/#$CONTAINER_PARENT/$HOST_PARENT}"

    echo "$WIN_GITDIR" > "$WORKTREE_GITDIR/gitdir"
    echo "Worktree created: $WORKTREE_PATH"
    echo "  Host gitdir: $WIN_GITDIR"
else
    echo "Worktree created: $WORKTREE_PATH"
    echo "  Warning: HOST_WORKSPACE/CONTAINER_WORKDIR not set, gitdir left as container path"
fi

# Strip mismatched upstream tracking — a branch created from origin/main inherits
# "merge = refs/heads/main", which causes git push to silently target main instead
# of a dedicated feature branch remote. Strip if the upstream branch name differs
# from the local branch name (e.g. feature/x tracking origin/main).
CURRENT_BRANCH=$(git -C "$WORKTREE_PATH" branch --show-current)
UPSTREAM_MERGE=$(git -C "$WORKTREE_PATH" config --get "branch.$CURRENT_BRANCH.merge" 2>/dev/null || true)
UPSTREAM_BRANCH="${UPSTREAM_MERGE#refs/heads/}"

if [ -n "$UPSTREAM_MERGE" ] && [ "$UPSTREAM_BRANCH" != "$CURRENT_BRANCH" ]; then
    git -C "$WORKTREE_PATH" branch --unset-upstream
    echo "  Upstream tracking cleared (was pointing to $UPSTREAM_MERGE — pushes must use an explicit target)."
fi
echo ""
git -C "$WORKTREE_PATH" branch -vv
